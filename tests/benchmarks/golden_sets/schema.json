{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CTS Golden Test Set",
  "description": "Schema for claude-token-saver benchmark golden sets",
  "type": "object",
  "required": ["repo", "queries"],
  "properties": {
    "repo": {
      "type": "string",
      "description": "Repository identifier (e.g. 'claude-token-saver')"
    },
    "repo_path": {
      "type": "string",
      "description": "Optional path to the repository on disk"
    },
    "languages": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Languages present in the repo"
    },
    "queries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "category", "query", "difficulty", "expected_results"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique query identifier (e.g. 'cts-001')"
          },
          "category": {
            "type": "string",
            "enum": [
              "exact_name",
              "exact_function",
              "concept_single_lang",
              "concept_cross_lang",
              "pattern_usage",
              "error_handling",
              "data_flow"
            ]
          },
          "query": {
            "type": "string",
            "description": "Natural language or exact query string"
          },
          "difficulty": {
            "type": "string",
            "enum": ["easy", "medium", "hard"]
          },
          "expected_results": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["file", "name", "relevance"],
              "properties": {
                "file": {
                  "type": "string",
                  "description": "Relative path to the source file"
                },
                "name": {
                  "type": "string",
                  "description": "Function, class, or symbol name"
                },
                "relevance": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 3,
                  "description": "Graded relevance: 3=direct answer, 2=necessary context, 1=marginal, 0=irrelevant"
                }
              }
            }
          },
          "coverage_dirs": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Directory prefixes that must be represented in results"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
